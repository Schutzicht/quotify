{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        }
    ],
    "functions": {
        "api/index.js": {
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/cron/generate-blog",
            "schedule": "0 9 * * *"
        }
    ]
}
